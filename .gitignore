# SLG Sentinel — 安全忽略规则

# ── Python 编译产物 ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── 虚拟环境 ─────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / 编辑器 ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── 敏感凭证（绝不提交！） ───────────────────────────────────
.env
.env.*
*.env
secrets.yaml
cookies.txt
*.json.cookies
bili_cookies.json

# ── 日志 ─────────────────────────────────────────────────────
*.log
logs/

# ── 临时文件与调试残留 ───────────────────────────────────────
/tmp/
*.tmp
scratch.py
spider_slg_full.py

# ── 数据目录（由 data 分支管理，不跟踪到 main） ─────────────
# data/
# reports/

# ── 外部文档残留（不纳入版本管理） ───────────────────────────
copilot.txt
copilot.*.pdf
spec.txt
*.docx

# ── 测试缓存 ─────────────────────────────────────────────────
.pytest_cache/

# ── Streamlit 缓存 ───────────────────────────────────────────
.streamlit/

# ── AI Agent 上下文目录 ──────────────────────────────────────
.gemini/
